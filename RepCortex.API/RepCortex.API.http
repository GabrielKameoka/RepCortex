@RepCortex.API_HostAddress = https://repcortex-production.up.railway.app

# ==============================================================================
# 1. REGISTRAR NOVO TENANT
# Cadastra uma nova loja/e-commerce diretamente na API de Produção.
# Copie o 'publishableKey' e 'tokenJWT' da resposta para usar nos testes seguintes.
# ==============================================================================
# @name RegistrarTenant
POST {{RepCortex.API_HostAddress}}/api/auth/registrar
Content-Type: application/json

{
  "tenantIdSlug": "loja-exemplo-abc",
  "nomeComercial": "E-Commerce Exemplo ABC S/A",
  "nomeCompletoUsuario": "Gabriel Kameoka",
  "email": "gabriel@exemplo.com",
  "senha": "SenhaSegura123!"
}

###

# ==============================================================================
# CONFIGURAÇÃO DE SESSÃO DO PLAYGROUND
# Substitua os valores abaixo pelos gerados no endpoint acima para rodar o fluxo!
# ==============================================================================
@publishableKey = {{RegistrarTenant.response.body.publishableKey}}
@adminToken = {{RegistrarTenant.response.body.tokenJWT}}

###

# ==============================================================================
# 2. LOGIN (ADMINISTRADOR)
# Caso precise gerar um novo token JWT posteriormente.
# ==============================================================================
POST {{RepCortex.API_HostAddress}}/api/auth/login
Content-Type: application/json

{
  "tenantId": "loja-exemplo-abc",
  "email": "gabriel@exemplo.com",
  "senha": "SenhaSegura123!"
}

###

# ==============================================================================
# 3. ENVIAR AVALIAÇÃO - SENTIMENTO POSITIVO (AUTO-APROVAÇÃO)
# Nota 5 com comentário elogiando o produto. Deve ser classificado como Positivo
# e obter o status 'Aprovada' automaticamente pelo domínio.
# ==============================================================================
POST {{RepCortex.API_HostAddress}}/api/public/avaliacoes
X-Api-Key: {{publishableKey}}
Content-Type: application/json

{
  "clienteId": "cli-12345",
  "usuarioIdExterno": "usr_999",
  "produtoId": "prod-777",
  "nota": 5,
  "comentario": "O produto é excelente, amei demais! Superou todas as expectativas.",
  "ipOrigem": "127.0.0.1",
  "fingerprint": "dispositivo_hash_hash"
}

###

# ==============================================================================
# 4. ENVIAR AVALIAÇÃO - SENTIMENTO NEGATIVO (RETIDA COMO PENDENTE - IRONIA)
# Nota 5, mas com comentário irônico/negativo. O ML.NET classificará como Negativo
# e o domínio forçará o status para 'Pendente' para validação do lojista.
# ==============================================================================
POST {{RepCortex.API_HostAddress}}/api/public/avaliacoes
X-Api-Key: {{publishableKey}}
Content-Type: application/json

{
  "clienteId": "cli-12345",
  "usuarioIdExterno": "usr_999",
  "produtoId": "prod-888",
  "nota": 5,
  "comentario": "Odiei, a caixa veio rasgada e faltou peça.",
  "ipOrigem": "127.0.0.1",
  "fingerprint": "dispositivo_hash_hash"
}

###

# ==============================================================================
# 5. ENVIAR AVALIAÇÃO - NOTA BAIXA (RETIDA COMO PENDENTE)
# Nota 1 (recomenda-se retenção independente de sentimento).
# ==============================================================================
POST {{RepCortex.API_HostAddress}}/api/public/avaliacoes
X-Api-Key: {{publishableKey}}
Content-Type: application/json

{
  "clienteId": "cli-12345",
  "usuarioIdExterno": "usr_999",
  "produtoId": "prod-999",
  "nota": 1,
  "comentario": "Material fraco e entrega demorou demais.",
  "ipOrigem": "127.0.0.1",
  "fingerprint": "dispositivo_hash_hash"
}

###

# ==============================================================================
# 6. OBTER TODAS AS AVALIAÇÕES (ADMINISTRADOR)
# Requer autenticação JWT de Administrador. Retorna as avaliações do Tenant
# com seus respectivos status (Aprovada, Pendente) e sentimentos previstos.
# ==============================================================================
GET {{RepCortex.API_HostAddress}}/api/admin/avaliacoes
Authorization: Bearer {{adminToken}}
Accept: application/json

