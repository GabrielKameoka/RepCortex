{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "dotnet publish RepCortex.API/RepCortex.API.csproj -c Release -o out"
  },
  "deploy": {
    "startCommand": "dotnet out/RepCortex.API.dll",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  },
  "variables": {
    "NIXPACKS_DOTNET_VERSION": "10.0"
  }
}